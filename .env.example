GOOGLE_SERVICE_ACCOUNT_FILE=./credentials/service-account.json
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_DELEGATED_USER=
GOOGLE_SPREADSHEET_ID=
GOOGLE_TEMPLATE_PRESENTATION_ID=
GOOGLE_OUTPUT_FOLDER_ID=
GOOGLE_COORD_RANGE=Coord_Status_Report!A2:C
GOOGLE_CLIENTS_RANGE=Clientes!A2:G
GOOGLE_DATA_RANGE=Agenda da Semana!A1:G200
GOOGLE_PROJECTS_INDEX_RANGE=Projetos_Funcionais!A1:B300
TIMEZONE=America/Sao_Paulo
RUN_ONLY_WEEKDAYS=true
DRY_RUN=false
SAVE_LOCAL_DOWNLOAD=true
LOCAL_DOWNLOAD_FOLDER=

# Banco Oracle (ERP GHR) - usado para listar projetos do cliente e Controle de Horas
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_HOST=
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=
# Pasta do Oracle Instant Client 64-bit (modo thick, obrigatorio p/ o ERP)
# Vazio: detecta automaticamente a pasta instantclient* na raiz do projeto
ORACLE_CLIENT_LIB_DIR=
# Schema onde ficam as tabelas do ERP (ex.: GHR)
ORACLE_SCHEMA=GHR

# SAVE_LOCAL_DOWNLOAD: salva PDF e PPTX completos na maquina (padrao: true)
# LOCAL_DOWNLOAD_FOLDER: pasta local (vazio = ~/Downloads/Status Report GHR)

# Aba Coord_Status_Report (somente coordenadoras):
#   A=coordenadora, B=ativo, C=email
#
# Aba Clientes (cadastro centralizado):
#   A=codigo_cliente, B=nome_curto, C=cliente_id_completo,
#   D=nome_pdf_customizado, E=ativo, F=dias_semana, G=nr_seq_cliente (Oracle)
#
# Aba Projetos_Funcionais:
#   A=id_projeto (ex: "ID: 0078-25-HONORP SUPCON"), B=link_planilha
#
# GOOGLE_DELEGATED_USER: usuario da empresa para delegacao de dominio (DWD)
